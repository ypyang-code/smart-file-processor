# ============================================================
# Smart File Processor · 环境变量模板
# ============================================================
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 编辑 .env，填入真实配置值
#   3. docker compose up -d 会自动读取 .env
#   4. 启动应用前请将 .env 中的变量 export 到当前 shell:
#      Linux/macOS:  source .env && export $(cut -d= -f1 .env)
#      或手动:       export MYSQL_PASSWORD=your_password
#      Windows:      在系统环境变量中逐项设置
#
# 注意:
#   - .env 文件已被 .gitignore 排除，不会提交到 Git
#   - 请勿将真实密钥填入此模板文件
# ============================================================

# ==================== MySQL ====================
MYSQL_PORT=3306
MYSQL_PASSWORD=your_mysql_password

# ==================== RabbitMQ ====================
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ==================== Elasticsearch ====================
ES_PORT=9200

# ==================== 阿里云 OSS（生产环境必需） ====================
# 开发调试时可以不填 OSS 配置，上传功能会因 OSS 初始化失败而阻止启动。
# 如果仅测试分片上传/搜索等不依赖 OSS 的功能，可临时注释掉 OSS 依赖后启动。
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name

# ==================== 文件上传 ====================
FILE_UPLOAD_DIR=uploads
